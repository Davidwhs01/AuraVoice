{
  "name": "auravoice",
  "version": "1.0.0",
  "description": "Chat de voz imersivo com servidores e transmissão de tela",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "vite build && electron-packager . AuraVoice --overwrite --out=release",
    "electron:installer": "npm run electron:build && node build-installer.js"
  },
  "build": {
    "appId": "com.auravoice.app",
    "productName": "AuraVoice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
